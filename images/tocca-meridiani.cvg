<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 500">
  <rect width="800" height="500" fill="#EDE7F6"/>

  <text x="400" y="42" text-anchor="middle" font-family="Arial" font-size="32" font-weight="bold" fill="#4527A0">
    Tocca Greenwich e i Poli
  </text>

  <circle cx="400" cy="260" r="165" fill="#B3E5FC" stroke="#1565C0" stroke-width="5"/>

  <ellipse cx="400" cy="260" rx="45" ry="165" fill="none" stroke="#E53935" stroke-width="5"/>
  <ellipse cx="400" cy="260" rx="90" ry="165" fill="none" stroke="#E53935" stroke-width="4"/>
  <line x1="400" y1="95" x2="400" y2="425" stroke="#D50000" stroke-width="10"/>

  <circle cx="400" cy="95" r="18" fill="#1A237E"/>
  <text x="400" y="103" text-anchor="middle" font-family="Arial" font-size="22" font-weight="bold" fill="white">N</text>

  <circle cx="400" cy="425" r="18" fill="#1A237E"/>
  <text x="400" y="433" text-anchor="middle" font-family="Arial" font-size="22" font-weight="bold" fill="white">S</text>

  <rect x="430" y="105" width="310" height="48" rx="16" fill="#FFFFFF" stroke="#D50000" stroke-width="3"/>
  <text x="585" y="137" text-anchor="middle" font-family="Arial" font-size="22" font-weight="bold" fill="#D50000">
