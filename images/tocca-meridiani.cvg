  </text>
  <path d="M430 130 L402 160" stroke="#D50000" stroke-width="4"/>

  <path d="M400 260 Q470 210 505 155" fill="none" stroke="#6A1B9A" stroke-width="7"/>
  <polygon points="505,155 487,163 502,176" fill="#6A1B9A"/>

  <rect x="500" y="230" width="190" height="50" rx="16" fill="#FFFFFF" stroke="#6A1B9A" stroke-width="3"/>
  <text x="595" y="263" text-anchor="middle" font-family="Arial" font-size="24" font-weight="bold" fill="#6A1B9A">
    Longitudine
  </text>

  <rect x="80" y="105" width="170" height="45" rx="16" fill="#FFFFFF" stroke="#1A237E" stroke-width="3"/>
  <text x="165" y="136" text-anchor="middle" font-family="Arial" font-size="23" font-weight="bold" fill="#1A237E">
    Polo Nord
  </text>

  <rect x="80" y="380" width="170" height="45" rx="16" fill="#FFFFFF" stroke="#1A237E" stroke-width="3"/>
  <text x="165" y="411" text-anchor="middle" font-family="Arial" font-size="23" font-weight="bold" fill="#1A237E">
